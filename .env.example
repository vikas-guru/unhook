# Copy to .env and fill in. .env is gitignored.

# Gemini — get a key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Firebase — Console > Project settings > Your apps > Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend-only SMTP secrets.
# Do not expose SMTP passwords through VITE_* variables or browser localStorage.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=notify@eshipjet.ai
SMTP_PASS=
SMTP_FROM_EMAIL=notify@eshipjet.ai
SMTP_FROM_NAME=Unhook Coach
